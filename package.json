{
  "name": "chainsaw-openproject-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:create": "PGPASSWORD=postgres createdb -h localhost -U postgres compact_tracker || true",
    "setup": "npm run db:up && npm run prisma:migrate && npm run prisma:generate",
    "setup:local": "npm run db:create && npm run prisma:migrate && npm run prisma:generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:openproject:clickup": "tsx scripts/seed-openproject-from-clickup.ts",
    "oxlint": "oxlint . --fix",
    "lint": "npm run oxlint",
    "test:code": "tsx --test tests/*.test.ts",
    "test": "npm run format && npm run lint && npm run test:code",
    "format": "oxfmt --write \"**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@mantine/core": "9.2.1",
    "@mantine/dropzone": "9.2.1",
    "@mantine/form": "9.2.1",
    "@mantine/hooks": "9.2.1",
    "@prisma/client": "^6.19.0",
    "@tabler/icons-react": "^3.35.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "prisma": "^6.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "turndown": "^7.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.0",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "concurrently": "^9.2.1",
    "globals": "^16.5.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "postcss": "^8.5.14",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
